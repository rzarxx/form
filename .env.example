# =========================================================================
# PERSONAL FORM BUILDER ENVIRONMENT CONFIGURATION
# =========================================================================

# 1. Admin Authentication Password
# Sandi ini digunakan untuk masuk ke panel dasbor admin (/login)
ADMIN_PASSWORD=sandi_admin_rahasia_anda

# 2. Database Connection URL
# URL koneksi untuk PostgreSQL database (Supabase, Neon, Vercel Postgres, atau Lokal)
# Contoh Supabase: postgresql://postgres:password@db.supabase.co:5432/postgres
# Contoh Vercel Postgres / Neon: postgres://user:pass@ep-hostname.us-east-2.aws.neon.tech/neondb
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# 3. Vercel Blob Token (Opsional)
# Masukkan token ini jika Anda ingin mengunggah berkas menggunakan Vercel Blob Storage di Vercel.
# Jika kosong, sistem otomatis menggunakan penyimpanan lokal (public/uploads) sebagai fallback.
BLOB_READ_WRITE_TOKEN=

# 4. Resend Email Notification (Opsional)
# Masukkan API Key dari Resend.com jika ingin notifikasi email nyata dikirim ke inbox Anda.
# Contoh: re_aBcdEfGh...
RESEND_API_KEY=

# 5. OpenRouter AI Form Builder (Opsional)
# Masukkan API Key dari OpenRouter.ai untuk mengaktifkan asisten AI secara global untuk admin.
# Contoh: sk-or-v1-abcdef...
OPENROUTER_API_KEY=

# Model default OpenRouter yang ingin digunakan di server (Opsional, bawaan: google/gemini-2.5-flash)
OPENROUTER_MODEL=google/gemini-2.5-flash
